{
  "version": 2,
  "ignoreCommand": "! git diff HEAD~1 --name-only | grep -qvE '^data/'",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/daily-summary",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/sync-stock",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/follow-up-cron",
      "schedule": "0 21 * * *"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
